# SOP Processor Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Google Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
REACT_APP_GEMINI_API_KEY=your_gemini_api_key_here

# File Processing Configuration
# Maximum file size in bytes (default: 10MB)
REACT_APP_MAX_FILE_SIZE=10485760

# Supported file formats (MIME types)
REACT_APP_SUPPORTED_FORMATS=text/plain,application/pdf

# Demo Configuration
# Enable/disable demo mode with sample documents
REACT_APP_DEMO_MODE=true

# Development Configuration
# Enable debug logging and development features
REACT_APP_DEBUG_MODE=true